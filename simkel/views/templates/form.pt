<div metal:use-macro="load: simkel:views/templates/base.pt">
    <div metal:fill-slot="content">
        <div class="row">
            <div class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
                <h1 class="page-title txt-color-blueDark">
                    <i class="fa-fw fa fa-edit"></i> 
                    Simkel <span>> ${title}</span>
                </h1>
            </div>
        </div>

        <section id="widget-grid">
            <div class="row">
                <article class="col-sm-12 col-md-12 col-lg-12">
                    <div class="panel panel-default">
                        <div class="panel-heading">
                            <h3 class="panel-title">
                                <i class="fa fa-fw fa-pencil-square-o"></i>&nbsp;${title}
                            </h3>
                        </div>
                        
                        <div class="panel-body">
                            <div class="form-horizontal" tal:condition="form">
                                <tal:block tal:content="structure form"/>
                            </div>

                            <div class="form-horizontal" tal:condition="python: row and not form">
                                <div class="form-group" tal:condition="python: hasattr(row, 'id')">
                                    <label class="col-md-3 control-label">ID Sistem</label>
                                    <div class="col-md-9">
                                        <p class="form-control-static"><strong>#${row.id}</strong></p>
                                    </div>
                                </div>
                                <div class="form-group" tal:condition="python: hasattr(row, 'kode')">
                                    <label class="col-md-3 control-label">Kode Field</label>
                                    <div class="col-md-9">
                                        <p class="form-control-static" tal:content="row.kode or '-'"></p>
                                    </div>
                                </div>
                                <div class="form-group" tal:condition="python: hasattr(row, 'nama')">
                                    <label class="col-md-3 control-label">Nama / Label</label>
                                    <div class="col-md-9">
                                        <p class="form-control-static" tal:content="row.nama or '-'"></p>
                                    </div>
                                </div>
                                <div class="form-group" tal:condition="python: hasattr(row, 'value')">
                                    <label class="col-md-3 control-label">Nilai (Value)</label>
                                    <div class="col-md-9">
                                        <p class="form-control-static" tal:content="row.value or '-'"></p>
                                    </div>
                                </div>
                                <div class="form-group" tal:condition="python: hasattr(row, 'status')">
                                    <label class="col-md-3 control-label">Status Data</label>
                                    <div class="col-md-9">
                                        <span tal:condition="python: row.status == 0" class="label label-default">Draft</span>
                                        <span tal:condition="python: row.status == 1" class="label label-warning">Menunggu Verifikasi</span>
                                        <span tal:condition="python: row.status == 2" class="label label-danger">Ditolak</span>
                                        <span tal:condition="python: row.status == 3" class="label label-info">Telah Disetujui (Siap Tetap)</span>
                                        <span tal:condition="python: row.status == 4" class="label label-success">Selesai / Ditetapkan</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="panel-footer">
                            <div class="row">
                                <div class="col-md-12">
                                    <a href="javascript:history.back()" class="btn btn-default">
                                        <i class="fa fa-arrow-left"></i> Kembali
                                    </a>
                                    
                                    <tal:block tal:condition="python: row and hasattr(row, 'status')">
                                        
                                        <tal:block tal:condition="python: not form and row.status == 1">
                                            <a tal:attributes="href python:request.current_route_url().replace('/view', '/approve')" 
                                               class="btn btn-success"
                                               onclick="return confirm('Setujui permohonan ini?')">
                                                <i class="fa fa-check"></i> Setujui
                                            </a>
                                            <a tal:attributes="href python:request.current_route_url().replace('/view', '/reject')" 
                                               class="btn btn-danger"
                                               onclick="return confirm('Tolak permohonan ini?')">
                                                <i class="fa fa-times"></i> Tolak
                                            </a>
                                        </tal:block>

                                        <tal:block tal:condition="python: not form and row.status == 3">
                                            <a tal:attributes="href python:request.current_route_url().replace('/view', '/tetapkan')" 
                                               class="btn btn-primary"
                                               onclick="return confirm('Tetapkan data ini dan generate TTE?')">
                                                <i class="fa fa-gavel"></i> Tetapkan (TTE)
                                            </a>
                                        </tal:block>

                                        <a tal:condition="python: row.status == 4"
                                           tal:attributes="href python:request.current_route_url().replace('/view', '/print')" 
                                           target="_blank"
                                           class="btn btn-success">
                                            <i class="fa fa-print"></i> Cetak SK Final
                                        </a>

                                    </tal:block>
                                </div>
                            </div>
                        </div>
                    </div>
                </article>
            </div>
        </section>
    </div>
</div>

<style>
    .panel-body { padding: 25px; }
    .control-label { font-weight: bold; text-align: left !important; color: #333; }
    .form-control-static { border-bottom: 1px solid #f0f0f0; padding-bottom: 5px; margin-bottom: 5px; display: block; }
    .panel-footer .btn { margin-right: 8px; min-width: 110px; }
    .label { padding: .3em .6em; font-size: 85%; }
    .deform fieldset { border: none !important; padding: 0 !important; }
</style>