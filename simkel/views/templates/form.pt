<div class="row">
    <div class="col-md-12">
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title">
                    <i class="fa fa-fw fa-edit"></i>&nbsp;${title}
                </h3>
            </div>

            <div class="panel-body">
                <div class="row">
                    <div class="col-md-12">
                        <div tal:replace="structure form">
                            Form Deform tidak terdeteksi.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    $(document).ready(function() {
        // Inisialisasi callback Deform (Penting buat JQuery Mask)
        if (typeof deform !== 'undefined') {
            deform.load();
        }

        // Custom styling untuk merapikan tombol bawaan deform 
        // agar mirip dengan style SmartAdmin
        $(".deform-form-buttons button#deforminquiry").addClass("btn btn-info");
        $(".deform-form-buttons button#deformclose").addClass("btn btn-danger");
        
        // Memastikan label form punya lebar yang pas (col-sm-3 dsb)
        $(".control-label").addClass("col-sm-3 col-md-2");
    });
</script>

<style>
    /* Tambahan CSS supaya form lebih rapi sesuai SS Abang */
    .panel-default > .panel-heading {
        background-color: #f5f5f5;
        font-weight: bold;
    }
    .deform-form-fieldset {
        border: none;
        padding: 0;
    }
    .form-group {
        margin-bottom: 15px;
    }
</style>