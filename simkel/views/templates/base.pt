<html metal:use-macro="load: opensipkd.base:views/templates/base5.pt" 
      metal:define-macro="main" 
      tal:omit-tag="">

  <span metal:fill-slot="navs" tal:omit-tag="">
    <ul style="margin-top: 0; padding-top: 0;">
      <li tal:repeat="menu get_simkel_menus()" 
          tal:attributes="class python:request.matched_route and request.matched_route.name in menu['route_name'] and 'active' or ''">
        
        <a tal:condition="python:not menu['children'] and (not menu['permission'] or has_permission(request, menu['permission']))"
           href="${home}${menu['path']}">
          <i tal:condition="menu['icon']" class="fa fa-lg fa-fw ${menu['icon']}"></i>
          <span>${menu['nama']}</span>
        </a>

        <a tal:condition="python:menu['children'] and (not menu['permission'] or has_permission(request, menu['permission']))"
           href="#">
          <i tal:condition="menu['icon']" class="fa fa-lg fa-fw ${menu['icon']}"></i>
          <span class="menu-item-parent">${menu['nama']}</span>
        </a>

        <ul tal:condition="python:menu['children'] and (not menu['permission'] or has_permission(request, menu['permission']))">
          <li tal:repeat="submenu menu['children']"
              tal:attributes="class python:request.matched_route and request.matched_route.name in submenu['route_name'] and 'active' or ''">
            <a href="${home}${submenu['path']}">
              <i tal:condition="submenu['icon']" class="fa fa-lg fa-fw ${submenu['icon']}"></i>
              <span>${submenu['nama']}</span>
            </a>
          </li>
        </ul>
      </li>
    </ul>
  </span>
</html>