<div tal:define="base base_template" tal:omit-tag="">
  <div metal:use-macro="base.macros['main']" tal:omit-tag="">
    <div metal:fill-slot="content">
      
      <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
      <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet">

      <div class="container py-4 px-3 px-md-4">
        
        <div class="bg-white rounded-4 shadow-sm px-4 py-4 mb-4 border-start border-primary border-5">
          <h2 class="mb-1 fw-bold text-dark"
              tal:content="python:'Dashboard ' + (dashboard_type.capitalize() if dashboard_type else 'User')">
              Dashboard
          </h2>
          <p class="text-muted mb-0 small">
            <i class="bi bi-person-badge me-1"></i> 
            Selamat datang, Anda masuk sebagai <b class="text-primary text-uppercase" tal:content="dashboard_type">Role</b>
          </p>
        </div>

        <div class="row g-4 mb-5">
          <div class="col-6 col-md-3">
            <div class="stat-card pending">
              <div class="stat-icon"><i class="fa fa-clock-o"></i></div>
              <div class="stat-content">
                <div class="stat-label">Pending</div>
                <div class="stat-value" tal:content="summary['draft']">0</div>
              </div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="stat-card process">
              <div class="stat-icon"><i class="fa fa-refresh"></i></div>
              <div class="stat-content">
                <div class="stat-label">Proses</div>
                <div class="stat-value" tal:content="summary['proses']">0</div>
              </div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="stat-card success">
              <div class="stat-icon"><i class="fa fa-check-circle"></i></div>
              <div class="stat-content">
                <div class="stat-label">Selesai</div>
                <div class="stat-value" tal:content="summary['selesai']">0</div>
              </div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="stat-card danger">
              <div class="stat-icon"><i class="fa fa-times-circle"></i></div>
              <div class="stat-content">
                <div class="stat-label">Ditolak</div>
                <div class="stat-value" tal:content="summary['ditolak']">0</div>
              </div>
            </div>
          </div>
        </div>

        <div class="card shadow-sm border-0 bg-white rounded-4 overflow-hidden">
          <div class="card-header bg-white py-4 px-4 border-bottom">
            <div class="row align-items-center">
              
              <div class="col-12 col-md-3 mb-3 mb-md-0">
                <h5 class="mb-0 fw-bold d-flex align-items-center">
                  <i class="bi bi-list-ul me-2 text-primary fs-4"></i> Daftar
                </h5>
              </div>

              <div class="col-12 col-md-6 mb-3 mb-md-0 text-md-start ps-md-5" tal:condition="dashboard_type == 'warga'">
                <a href="${request.route_url('simkel-permohonan-add')}" 
                   class="btn btn-success shadow px-4 rounded-pill d-inline-flex align-items-center justify-content-center mt-md-2"
                   style="height: 42px; min-width: 210px; margin-left: 15%;">
                  <i class="bi bi-plus-circle me-2"></i> Buat Permohonan Baru
                </a>
              </div>

              <div class="col-12 col-md-3 ms-auto">
                <div class="d-flex gap-2 justify-content-md-end mt-md-2">    
    <select id="jenisFilter" class="form-select shadow-sm border-light bg-light filter-custom" 
            style="width: 160px !important;" onchange="filterRows()">
      <option value="">Semua Jenis</option>
      <option value="Surat Domisili">Surat Domisili</option>
      <option value="Surat Usaha">Surat Usaha</option>
      <option value="Surat Tidak Mampu">Surat Tidak Mampu</option>
    </select>

    <select id="statusFilter" class="form-select shadow-sm border-light bg-light filter-custom" 
            style="width: 110px !important;" onchange="filterRows()">
      <option value="">Status</option>
      <option value="0">Pending</option>
      <option value="1">Proses</option>
      <option value="3">Selesai</option>
      <option value="4">Ditolak</option>
    </select>

  </div>
</div>

<style>
  .filter-custom {
      height: 30px !important;
      font-size: 0.85rem !important;
      border-radius: 5px;
      padding: 0 5px !important; 
      cursor: pointer;
      
      margin-left: -20px; 
      
      transition: all 0.2s ease;
  }

  /* Memberikan jarak khusus di antara filter pertama dan kedua */
  .filter-custom:first-child {
      margin-right: 15px !important;
      }

  
</style>

            </div>
          </div>

          <div class="card-body p-0">
            <div class="table-responsive d-none d-md-block px-3 pb-3">
              <table class="table table-hover align-middle mb-0" id="permohonanTable">
                <thead class="text-secondary small text-uppercase">
                  <tr>
                    <th class="ps-3 border-0 py-3">No</th>
                    <th class="border-0 py-3">ID / Pemohon</th>
                    <th class="border-0 py-3">Jenis Surat</th>
                    <th class="border-0 py-3 text-center">Status</th>
                    <th class="border-0 py-3 text-center">Aksi</th>
                  </tr>
                </thead>
                <tbody class="border-top-0">
                  <tr tal:repeat="item items"
                      tal:attributes="data-status item.status; data-jenis item.jenis_nm if hasattr(item,'jenis_nm') else ''">
                    <td class="ps-3" tal:content="repeat.item.number">1</td>
                    <td>
                      <div class="fw-bold text-dark" tal:content="item.id">PMH-001</div>
                      <div class="small text-muted" tal:content="item.pemohon_nm if hasattr(item,'pemohon_nm') else '-'">Nama</div>
                    </td>
                    <td tal:content="item.jenis_nm if hasattr(item,'jenis_nm') else '-'">Jenis</td>
                    <td class="text-center">
                      <span tal:define="st item.status"
                            tal:attributes="class python:'badge rounded-pill px-3 ' + ('bg-secondary' if st==0 else 'bg-warning text-dark' if st==1 else 'bg-success' if st==3 else 'bg-danger')"
                            tal:content="python:'Pending' if st==0 else 'Diproses' if st==1 else 'Disetujui' if st==3 else 'Ditolak'">
                      </span>
                    </td>
                    <td class="text-center">
                      <div class="btn-group shadow-sm border rounded overflow-hidden">
                        <a tal:attributes="href python:'/simkel/permohonan/' + str(item.id) + '/view'"
                           class="btn btn-sm btn-light text-info border-end" title="Detail"><i class="bi bi-eye-fill"></i></a>
                        
                        <tal:block tal:condition="dashboard_type == 'petugas' and item.status == 1">
                          <a href="#" class="btn btn-sm btn-light text-success border-end"><i class="bi bi-check-lg"></i></a>
                          <a href="#" class="btn btn-sm btn-light text-danger"><i class="bi bi-x-lg"></i></a>
                        </tal:block>

                        <tal:block tal:condition="dashboard_type == 'manager' and item.status == 1">
                          <a href="#" class="btn btn-sm btn-light text-primary fw-bold px-3">APPROVE</a>
                        </tal:block>
                      </div>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="d-md-none p-3" id="mobileCardList">
              <div tal:repeat="item items" class="mobile-card border shadow-sm p-3 mb-3 rounded-4 bg-white"
                   tal:attributes="data-status item.status; data-jenis item.jenis_nm">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <div>
                    <div class="fw-bold text-primary" tal:content="item.id">ID</div>
                    <div class="small text-dark fw-bold" tal:content="item.pemohon_nm">Nama</div>
                  </div>
                  <span tal:define="st item.status"
                        tal:attributes="class python:'badge rounded-pill ' + ('bg-secondary' if st==0 else 'bg-warning text-dark' if st==1 else 'bg-success' if st==3 else 'bg-danger')"
                        tal:content="python:'Pending' if st==0 else 'Diproses' if st==1 else 'Disetujui' if st==3 else 'Ditolak'"></span>
                </div>
                <hr class="my-2 opacity-25">
                <div class="small text-muted mb-3">
                  <i class="bi bi-file-earmark-text me-1"></i> <span tal:content="item.jenis_nm">Jenis Surat</span>
                </div>
                <div class="d-grid">
                  <a tal:attributes="href python:'/simkel/permohonan/' + str(item.id) + '/view'" 
                     class="btn btn-info text-white rounded-pill btn-sm shadow-sm">Lihat Detail</a>
                </div>
              </div>
            </div>

            <div tal:condition="not items" class="text-center py-5 text-muted">
              <i class="bi bi-inbox fs-1 d-block mb-2 opacity-25"></i>
              Belum ada data permohonan.
            </div>
          </div>
        </div>
      </div>

      <style>
        body { background-color: #f8fafb; font-family: 'Inter', sans-serif; }
        .rounded-4 { border-radius: 1rem !important; }
        
        .stat-card {
            display: flex; align-items: center; padding: 25px; border-radius: 16px;
            color: #fff; box-shadow: 0 8px 20px rgba(0,0,0,0.06);
            transition: all 0.3s ease; border: none; height: 100%;
        }
        .stat-card:hover { transform: translateY(-5px); }
        .stat-icon { font-size: 32px; opacity: 0.3; margin-right: 20px; }
        .stat-label { font-size: 11px; font-weight: 600; text-transform: uppercase; }
        .stat-value { font-size: 28px; font-weight: 800; line-height: 1; margin-top: 4px; }

        .pending { background: linear-gradient(135deg, #4b5563, #1f2937); } 
        .process { background: linear-gradient(135deg, #0ea5e9, #2563eb); } 
        .success { background: linear-gradient(135deg, #10b981, #059669); } 
        .danger  { background: linear-gradient(135deg, #f43f5e, #e11d48); } 

        .btn-success { background: linear-gradient(90deg, #09110e, #09110e); border: none; font-weight: 500; margin-bottom: 15px;}
        .mobile-card { border-left: 5px solid #0d6efd !important; }
        
        .select-custom {
            height: 42px !important;
            width: auto !important;
            min-width: 140px;
        }

        @media (min-width: 768px) { 
          .mt-md-2 { margin-top: 12px !important; } 
        }
      </style>

      <script>
        function filterRows() {
          let status = document.getElementById('statusFilter')?.value;
          let jenis = document.getElementById('jenisFilter')?.value;

          document.querySelectorAll('#permohonanTable tbody tr').forEach(row => {
            let rStat = row.getAttribute('data-status');
            let rJen = row.getAttribute('data-jenis');
            row.style.display = ((!status || rStat == status) && (!jenis || rJen == jenis)) ? '' : 'none';
          });

          document.querySelectorAll('#mobileCardList .mobile-card').forEach(card => {
            let cStat = card.getAttribute('data-status');
            let cJen = card.getAttribute('data-jenis');
            card.style.display = ((!status || cStat == status) && (!jenis || cJen == jenis)) ? '' : 'none';
          });
        }
      </script>

    </div>
  </div>
</div>