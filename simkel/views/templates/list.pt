<div metal:use-macro="load: simkel:views/templates/base.pt">
    <div metal:fill-slot="content">
        <tal:block tal:define="curr_route request.matched_route.name;
                               is_approval python:'approval' in curr_route;
                               items python:list(rows) if rows else []">
            
            <div class="well" style="background-color: #fff; border: 1px solid #e3e3e3; padding: 20px;">
                <form method="GET" action="">
                    <div class="row">
                        <div class="col-xs-12">
                            <div class="pull-left">
                                <button class="btn btn-warning btn-sm" type="button" data-toggle="collapse" data-target="#collapseFilter">
                                    <i class="fa fa-filter"></i> Sort & Options
                                </button>
                                <a tal:condition="not:is_approval"
                                   tal:attributes="href python:request.route_url(curr_route + '-add')"
                                   class="btn btn-success btn-sm" style="margin-left: 5px;">
                                    <i class="fa fa-plus"></i> Add
                                </a>
                            </div>

                            <div class="pull-right">
                                <div class="form-inline">
                                    <label>Search: </label>
                                    <input type="search" name="search" 
                                           tal:attributes="value request.params.get('search', '')"
                                           class="form-control input-sm" 
                                           style="width: 200px; margin-left: 10px;"
                                           placeholder="Kata kunci...">
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        <i class="fa fa-search"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="collapse" id="collapseFilter" style="margin-top: 15px;">
                        <div class="panel panel-default">
                            <div class="panel-body" style="background-color: #fcfcfc;">
                                <div class="row">
                                    <div class="col-md-4">
                                        <label>Urutkan</label>
                                        <select name="sort" class="form-control input-sm" onchange="this.form.submit()">
                                            <option value="id_desc" tal:attributes="selected python:request.params.get('sort') == 'id_desc'">Terbaru</option>
                                            <option value="id_asc" tal:attributes="selected python:request.params.get('sort') == 'id_asc'">Terlama</option>
                                            <option value="nama_asc" tal:attributes="selected python:request.params.get('sort') == 'nama_asc'">Nama (A-Z)</option>
                                            <option value="nama_desc" tal:attributes="selected python:request.params.get('sort') == 'nama_desc'">Nama (Z-A)</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label>Status</label>
                                        <select name="status" class="form-control input-sm" onchange="this.form.submit()">
                                            <option value="">-- Semua Status --</option>
                                            <option value="0" tal:attributes="selected python:request.params.get('status') == '0'">Draft</option>
                                            <option value="1" tal:attributes="selected python:request.params.get('status') == '1'">Proses</option>
                                            <option value="2" tal:attributes="selected python:request.params.get('status') == '2'">Revisi</option>
                                            <option value="3" tal:attributes="selected python:request.params.get('status') == '3'">Selesai</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label>Baris</label>
                                        <select name="limit" class="form-control input-sm" onchange="this.form.submit()">
                                            <option value="25" tal:attributes="selected python:request.params.get('limit') == '25'">25</option>
                                            <option value="50" tal:attributes="selected python:request.params.get('limit') == '50'">50</option>
                                            <option value="100" tal:attributes="selected python:request.params.get('limit') == '100'">100</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>

                <div class="table-responsive" style="margin-top: 15px;">
                    <table class="table table-bordered table-hover">
                        <thead>
                            <tr style="background-color: #f9f9f9;">
                                <th class="text-center" style="width: 120px;">Action</th>
                                <th class="text-center" style="width: 50px;">No</th>
                                <th>Nama / Deskripsi</th>
                                <th class="text-center">Kode / Info</th>
                                <th class="text-center" style="width: 100px;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr tal:repeat="item items">
                                <td class="text-center" style="vertical-align: middle;">
                                    <tal:block tal:define="item_id python:getattr(item, 'id', 0);
                                                           st python:int(getattr(item, 'status', 0))">
                                        <div class="btn-group">
                                            <a tal:attributes="href python:request.route_url(curr_route + '-view', id=item_id)"
                                               title="View"><i class="fa fa-eye text-primary"></i></a>
                                            
                                            <tal:block tal:condition="not:is_approval">
                                                <span tal:condition="python:st in [0, 2]" style="margin-left: 10px;">
                                                    <a tal:attributes="href python:request.route_url(curr_route + '-edit', id=item_id)"
                                                       title="Edit"><i class="fa fa-pencil text-info"></i></a>
                                                    <a tal:attributes="href python:request.route_url(curr_route + '-delete', id=item_id)"
                                                       onclick="return confirm('Hapus?')" style="margin-left: 10px;"
                                                       title="Delete"><i class="fa fa-trash text-danger"></i></a>
                                                </span>
                                            </tal:block>
                                        </div>
                                    </tal:block>
                                </td>
                                <td class="text-center" style="vertical-align: middle;" tal:content="python:repeat.item.index + 1"></td>
                                <td style="vertical-align: middle;">
                                    <strong tal:content="python:getattr(item, 'nama', getattr(item, 'description', '-'))"></strong>
                                    <small class="text-muted" style="display:block; font-size: 10px;">ID: ${getattr(item, 'id', '0')}</small>
                                </td>
                                <td class="text-center" style="vertical-align: middle;" 
                                    tal:content="python:getattr(item, 'kode', getattr(item, 'value', '-'))"></td>
                                <td class="text-center" style="vertical-align: middle;">
                                    <tal:block tal:define="st python:int(getattr(item, 'status', 0))">
                                        <span tal:condition="python:st == 3" class="label label-success">SELESAI</span>
                                        <span tal:condition="python:st == 1" class="label label-warning">PROSES</span>
                                        <span tal:condition="python:st == 2" class="label label-danger">REVISI</span>
                                        <span tal:condition="python:st == 0" class="label label-default">DRAFT</span>
                                    </tal:block>
                                </td>
                            </tr>
                            <tr tal:condition="not items">
                                <td colspan="5" class="text-center">Data tidak ditemukan.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </tal:block>
    </div>
</div>